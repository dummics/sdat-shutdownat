<Window
    x:Class="Sdat.App.CriticalOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        x:Name="OverlayRoot"
        Padding="16"
        CornerRadius="10"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1">
        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="2">
                <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock x:Name="CountdownText" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <ProgressBar
                Grid.Row="1"
                x:Name="CountdownProgress"
                Minimum="0"
                Maximum="100"
                Height="8" />
            <StackPanel
                Grid.Row="2"
                x:Name="ActionPanel"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right">
                <Button x:Uid="DismissButton" x:Name="DismissButton" Content="Dismiss" Click="OnDismiss" />
                <Button x:Uid="SnoozeButton" x:Name="SnoozeButton" Content="Snooze 10 min" Click="OnSnooze" />
                <Button x:Uid="CancelButton" x:Name="CancelButton" Content="Cancel" Style="{ThemeResource AccentButtonStyle}" Click="OnCancel" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
